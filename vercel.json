{
  "experimentalServices": {
    "web": {
      "root": "apps/web",
      "framework": "vite"
    },
    "relay": {
      "root": "services/relay"
    }
  },
  "rewrites": [
    {
      "source": "/group-ws",
      "destination": { "type": "service", "service": "relay" }
    },
    {
      "source": "/livekit-token",
      "destination": { "type": "service", "service": "relay" }
    },
    {
      "source": "/livekit-config",
      "destination": { "type": "service", "service": "relay" }
    },
    {
      "source": "/openclaw(/.*)?",
      "destination": { "type": "service", "service": "relay" }
    },
    {
      "source": "/(.*)",
      "destination": { "type": "service", "service": "web" }
    }
  ]
}
